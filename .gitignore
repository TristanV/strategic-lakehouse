# ─────────────────────────────────────────────
# Strategic Lakehouse — .gitignore
# Tristan Vanrullen — 2026
# ─────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Environnements virtuels (pip/venv) ─────────
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Conda ───────────────────────────────────
# Dossiers d'environnement conda locaux (si créés dans le projet)
conda-env/
.conda/
envs/
# Fichier environment.yml généré automatiquement (non versionné par défaut)
# Décommentez la ligne ci-dessous si vous ne voulez PAS versionner environment.yml
# environment.yml

# ── Variables d'environnement & secrets ────────
.env
.env.*
*.env
secrets.yaml
secrets.json
credentials.json
.netrc

# ── Jupyter ────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py
# Les outputs de notebooks sont nettoyés automatiquement
# par nbstripout (hook git installé via `nbstripout --install`)

# ── DuckDB ────────────────────────────────
*.duckdb
*.duckdb.wal

# ── Données brutes & traitées ─────────────────
# Les datasets Kaggle et les fichiers générés ne sont pas versionnés
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json
data/silver/*.parquet
data/silver/*.csv
data/gold/*.parquet
data/gold/*.csv
# Conserver les README et .gitkeep dans chaque dossier
!data/raw/README.md
!data/raw/.gitkeep
!data/silver/README.md
!data/silver/.gitkeep
!data/gold/README.md
!data/gold/.gitkeep

# ── Logs & monitoring ────────────────────────
*.log
logs/
*.out
airflow/logs/
mlflow/

# ── Artefacts ML / modèles ───────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.onnx
models/artifacts/

# ── Outils data quality ─────────────────────
# Great Expectations
great_expectations/.ge_store_backend_id
great_expectations/uncommitted/

# Soda
.soda/
soda_project.yml.bak

# ── dbt ────────────────────────────────────
# Paquets dbt installés localement
dbt_packages/
# Dossier de compilation dbt
target/
dbt_project.yml.bak
# Profil dbt local (contient des credentials)
~/.dbt/profiles.yml

# ── OpenLineage ───────────────────────────
.openlineage/
openlineage.yml.bak

# ── IDEs & éditeurs ────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Tests & couverture ─────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Mypy / type checking ───────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff / linters ─────────────────────────
.ruff_cache/

# ── Packaging & distribution ─────────────────
*.whl
*.tar.gz
*.zip

# ── Documentation générée ───────────────────
docs/_build/
site/

# ── Fichiers temporaires OS ──────────────────
.DS_Store
.AppleDouble
.LSOverride
desktop.ini
$RECYCLE.BIN/

# ── FastAPI / Uvicorn ──────────────────────
*.pid
.uvicorn/

# ── Airflow (Phase 3 optionnel) ──────────────
airflow.cfg
airflow.db
airflow/dags/__pycache__/
airflow/plugins/__pycache__/

# ── Docker (Phase 3 optionnel) ──────────────
.dockerignore
docker-compose.override.yml
