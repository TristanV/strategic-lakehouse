# ─────────────────────────────────────────────
# Strategic Lakehouse — .gitignore
# Tristan Vanrullen — 2026
# ─────────────────────────────────────────────

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Environnements virtuels ──────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
# Conda (si envs locaux)
conda-env/
.conda/

# ── Variables d'environnement & secrets ──────
.env
.env.*
*.env
secrets.yaml
secrets.json
credentials.json

# ── Jupyter ──────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py
# Conserver les .ipynb vides ou initiaux ; ignorer les outputs lourds
# (pour exclure les outputs : utiliser nbstripout en CI)

# ── DuckDB ───────────────────────────────────
*.duckdb
*.duckdb.wal

# ── Données brutes & traitées ────────────────
# Les datasets Kaggle et les fichiers générés ne sont pas versionnés
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json
data/silver/*.parquet
data/silver/*.csv
data/gold/*.parquet
data/gold/*.csv
# Conserver les README et .gitkeep dans chaque dossier
!data/raw/README.md
!data/raw/.gitkeep
!data/silver/README.md
!data/silver/.gitkeep
!data/gold/README.md
!data/gold/.gitkeep

# ── Logs & monitoring ────────────────────────
*.log
logs/
*.out
airflow/logs/
mlflow/

# ── Artefacts ML / modèles ───────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.onnx
models/artifacts/

# ── Outils data quality ──────────────────────
# Great Expectations
great_expectations/.ge_store_backend_id
great_expectations/uncommitted/

# ── dbt ──────────────────────────────────────
dbt_packages/
target/
dbt_project.yml.bak

# ── IDEs & éditeurs ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Tests & couverture ───────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Mypy / type checking ─────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff / linters ───────────────────────────
.ruff_cache/

# ── Packaging & distribution ─────────────────
*.whl
*.tar.gz
*.zip

# ── Documentation générée ────────────────────
docs/_build/
site/

# ── Fichiers temporaires OS ──────────────────
.DS_Store
.AppleDouble
.LSOverride
desktop.ini
$RECYCLE.BIN/
