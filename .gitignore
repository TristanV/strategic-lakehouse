# ─────────────────────────────────────────────────────────────
# Strategic Lakehouse — .gitignore
# Tristan Vanrullen — 2026
# ─────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Environnements virtuels (pip/venv) ────────────────────────
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Conda ─────────────────────────────────────────────────────
# Dossiers d'environnement conda locaux (si créés dans le projet)
conda-env/
.conda/
envs/
# environment.yml est versionné (utile pour reproductibilité).
# Décommentez la ligne ci-dessous pour l'ignorer si vous préférez
# environment.yml

# ── Variables d'environnement & secrets ───────────────────────
.env
.env.*
*.env
secrets.yaml
secrets.json
credentials.json
.netrc

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py
# Les outputs de notebooks sont nettoyés automatiquement
# par nbstripout (hook git local : nbstripout --install)

# ── DuckDB ────────────────────────────────────────────────────
*.duckdb
*.duckdb.wal

# ── Données brutes & transformées ─────────────────────────────
# Les datasets Kaggle et fichiers générés ne sont pas versionnés
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json
data/raw/*.xlsx
data/silver/*.parquet
data/silver/*.csv
data/gold/*.parquet
data/gold/*.csv
# Conserver les README et .gitkeep de chaque couche
!data/raw/README.md
!data/raw/.gitkeep
!data/silver/README.md
!data/silver/.gitkeep
!data/gold/README.md
!data/gold/.gitkeep

# ── Logs & monitoring ─────────────────────────────────────────
*.log
logs/
*.out
airflow/logs/
mlflow/

# ── Artefacts ML / modèles ────────────────────────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.onnx
models/artifacts/

# ── Great Expectations ────────────────────────────────────────
great_expectations/.ge_store_backend_id
great_expectations/uncommitted/

# ── Soda ──────────────────────────────────────────────────────
.soda/
soda_project.yml.bak

# ── dbt ───────────────────────────────────────────────────────
dbt_packages/
target/
dbt_project.yml.bak
# Le profil dbt contient des credentials — jamais versionné
~/.dbt/profiles.yml

# ── OpenLineage ───────────────────────────────────────────────
.openlineage/
openlineage.yml.bak

# ── IDEs & éditeurs ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.AppleDouble
.LSOverride

# ── Tests & couverture ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Mypy / type checking ──────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff / linters ────────────────────────────────────────────
.ruff_cache/

# ── Packaging & distribution ──────────────────────────────────
*.whl
*.tar.gz
*.zip

# ── Documentation générée ─────────────────────────────────────
docs/_build/
site/

# ── FastAPI / Uvicorn ─────────────────────────────────────────
*.pid
.uvicorn/

# ── Airflow (Phase 3 optionnel) ───────────────────────────────
airflow.cfg
airflow.db
airflow/dags/__pycache__/
airflow/plugins/__pycache__/

# ── Docker (Phase 3 optionnel) ────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── GitHub Actions (artefacts de build) ───────────────────────
.github/workflow-artifacts/

# ── Présentations & livrables temporaires ────────────────────
*.pptx
*.docx
*.pdf
# Garder les documents officiels dans documents/
!documents/**
!cadrage/**
